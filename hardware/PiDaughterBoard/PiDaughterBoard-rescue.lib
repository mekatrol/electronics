#
# STWD100-Power_Management
#
DEF STWD100-Power_Management U 0 40 Y Y 1 F N
F0 "U" 0 550 50 H V C CNN
F1 "STWD100-Power_Management" 0 450 50 H V C CNN
F2 "" 0 0 50 H I C CNN
F3 "" 0 0 50 H I C CNN
DRAW
S -450 350 0 -100 0 1 0 f
X WDO 1 100 50 100 L 50 50 0 0 O
X GND 2 -250 -200 100 U 50 50 0 0 W
X EN 3 -550 50 100 R 50 50 0 0 I
X WDI 4 -550 250 100 R 50 50 0 0 I
X VCC 5 100 250 100 L 50 50 0 0 W
ENDDRAW
ENDDEF
#
# TPS54331-Converter_DCDC
#
DEF TPS54331-Converter_DCDC U 0 40 Y Y 1 F N
F0 "U" 0 -50 50 H V C CNN
F1 "TPS54331-Converter_DCDC" 0 -150 50 H V C CNN
F2 "" 0 0 50 H I C CNN
F3 "" 0 0 50 H I C CNN
DRAW
