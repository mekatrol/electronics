X BOOT 1 -350 -300 100 R 50 50 0 0 O
X VIN 2 -350 -450 100 R 50 50 0 0 W
X EN 3 -350 -600 100 R 50 50 0 0 I
X SS 4 -350 -750 100 R 50 50 0 0 I
X VSENSE 5 400 -750 100 L 50 50 0 0 I
X COMP 6 400 -600 100 L 50 50 0 0 I
X GND 7 400 -450 100 L 50 50 0 0 W
X PH 8 400 -300 100 L 50 50 0 0 O
ENDDRAW
ENDDEF
