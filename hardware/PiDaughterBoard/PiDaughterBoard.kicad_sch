	(text "VINrms = [(VPWRrms / 0.707) - (D2vdrop + D3vdrop)] / PI * 1.414\n        = [(24VAC / 0.707) - (0.7 + 0.7)] / 3.14 * 1.414\n        = 14.65v"
		(exclude_from_sim no)
		(at 20.955 62.865 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "70e7ddb7-050f-47e5-9cdf-7e2dd09e5009")
	)
	(text "Vout = Vref x [R2 / (R3+R5) + 1]\n     = 0.8 x [10K / (1.8K + 0.1K) + 1]\n     = 5.01v"
		(exclude_from_sim no)
		(at 132.715 33.02 0)
		(effects
